# =============================================================================
# FAKE NEWS DETECTOR - ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED API KEYS
# -----------------------------------------------------------------------------

# Groq API Key (Required)
# Get your free API key from: https://console.groq.com
# Free tier: 30 requests/minute, 14,400 requests/day
GROQ_API_KEY=your-groq-api-key-here

# News API Key (Required)
# Get your free API key from: https://newsapi.org
# Free tier: 100 requests/day, 1,000 requests/month
NEWS_API_KEY=your-news-api-key-here

# -----------------------------------------------------------------------------
# FLASK CONFIGURATION
# -----------------------------------------------------------------------------

# Flask Secret Key (Required)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Flask Environment
FLASK_ENV=development
FLASK_DEBUG=true

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------

# Local SQLite Database
DATABASE_PATH=database/news.db

# PostgreSQL with pgvector (Optional - for RAG pipeline)
# Get free database from: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# OPTIONAL: ENHANCED FEATURES
# -----------------------------------------------------------------------------

# SerpAPI Key (Optional - for better news coverage)
# Get API key from: https://serpapi.com
# Free tier: 100 searches/month
SERPAPI_KEY=your-serpapi-key-here

# -----------------------------------------------------------------------------
# OPTIONAL: AUTHENTICATION & NOTIFICATIONS
# -----------------------------------------------------------------------------

# Google OAuth Configuration (Optional)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Email Configuration (Optional - for notifications)
# For Gmail: Use App Password (https://support.google.com/accounts/answer/185833)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true

# -----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# -----------------------------------------------------------------------------

# Password Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=15

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# -----------------------------------------------------------------------------
# MODEL CONFIGURATION
# -----------------------------------------------------------------------------

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# News API Settings
NEWS_API_LIMIT=15
REQUEST_TIMEOUT=10

# RAG Pipeline Settings
RAG_TOP_K_NEWS=10
RAG_TOP_K_VECTOR=5
RAG_RERANK_TOP=5

# -----------------------------------------------------------------------------
# DEVELOPMENT SETTINGS
# -----------------------------------------------------------------------------

# Allow requests without API keys (development only)
ALLOW_NO_API_KEY=false

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Cache Settings
CACHE_TIMEOUT=3600
ENABLE_CACHING=true

# -----------------------------------------------------------------------------
# PRODUCTION SETTINGS
# -----------------------------------------------------------------------------

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Security Headers
FORCE_HTTPS=false
SECURE_COOKIES=false

# Monitoring
ENABLE_METRICS=true
HEALTH_CHECK_INTERVAL=30
